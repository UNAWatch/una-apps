{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Clean All",
            "type": "shell",
            "command": "docker",
            "args": [
                "run",
                "--rm",
                "-v",
                "${workspaceFolder}/:/workspace",
                "xanderhendriks/stm32cubeide:16.0",
                "bash",
                "-c",
                "rm -rf /workspace/.vscode/workspace"
            ],
                        "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Build Cycling GUI",
            "type": "shell",
            "command": "docker",
            "args": [
                "run",
                "--rm",
                "-v",
                "${workspaceFolder}:/workspace",
                "-e",
                "GITHUB_WORKSPACE=/workspace",
                "-e",
                "PATH_SDK=/workspace/SDK",
                "xanderhendriks/stm32cubeide:16.0",
                "bash",
                "-c",
                ". /workspace/SDK/Utilities/Scripts/build-cube/setup-environment.sh && /workspace/SDK/Utilities/Scripts/build-cube/build-cube.sh /workspace/Apps/Cycling/Software/Apps/CyclingGUI-CubeIDE/"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": "$gcc"
        },
