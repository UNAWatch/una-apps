        {
            "label": "Clean All",
            "type": "shell",
            "command": "docker",
            "args": [
                "run",
                "--rm",
                "-v",
                "${workspaceFolder}/:/workspace",
                "xanderhendriks/stm32cubeide:16.0",
                "bash",
                "-c",
                "rm -rf /workspace/.vscode/workspace"
            ],
                        "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": true,
                "panel": "shared"
            }
        },
