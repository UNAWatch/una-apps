        {
            "label": "Build All (Core Only)",
            "dependsOn": [
                "Build Main Kernel (Core Only)",
                "Build Cycling GUI",
                "Build Cycling Service",
                "Build Glance1 Service",
                "Build GlanceARHR Service",
                "Build Hiking GUI",
                "Build Hiking Service"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": "$gcc",
            "options": {
                "env": {
                    "EXCLUDE_PRODTEST": "true"
                }
            }
        },
        {
